# MongoDB Replica Set Connection (for Docker Compose)
MONGODB_URI=mongodb://root:rootpassword@mongodb:27017/ib_techcase?authSource=admin&replicaSet=rs0

# JWT Config (Production Secrets)
JWT_SECRET=super_secret_production_key_123
JWT_REFRESH_SECRET=super_secret_production_refresh_key_123
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# CORS Config
CORS_ORIGIN=http://localhost:3000

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
