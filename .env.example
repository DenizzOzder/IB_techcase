# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database_name>?retryWrites=true&w=majority&appName=IBCluset

# JWT Config
JWT_SECRET=
JWT_REFRESH_SECRET=
